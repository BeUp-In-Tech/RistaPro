<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <title>You've Been Added – RistaPro</title>
  <!--[if mso]>
  <noscript>
    <xml>
      <o:OfficeDocumentSettings>
        <o:PixelsPerInch>96</o:PixelsPerInch>
      </o:OfficeDocumentSettings>
    </xml>
  </noscript>
  <![endif]-->
  <style>
    body, table, td, a { -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
    table, td { mso-table-lspace: 0pt; mso-table-rspace: 0pt; }
    img { -ms-interpolation-mode: bicubic; border: 0; height: auto; line-height: 100%; outline: none; text-decoration: none; }
    body { margin: 0; padding: 0; width: 100% !important; height: 100% !important; background-color: #f5f5f5; }
    body, td, p { font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; }

    @media only screen and (max-width: 600px) {
      .email-container { width: 100% !important; }
      .mobile-padding { padding: 24px 20px !important; }
      .info-card { margin-left: 0 !important; margin-right: 0 !important; }
    }
  </style>
</head>
<body style="margin: 0; padding: 0; background-color: #f5f5f5;">

  <!-- Preheader -->
  <div style="display: none; max-height: 0; overflow: hidden; font-size: 1px; line-height: 1px; color: #f5f5f5;">
    <%= ownerName %> has added you to manage <%= candidateName %>'s profile on RistaPro.
  </div>

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #f5f5f5;">
    <tr>
      <td align="center" style="padding: 40px 16px;">

        <!-- Email container -->
        <table role="presentation" class="email-container" width="560" cellpadding="0" cellspacing="0" border="0" style="background-color: #ffffff; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.06);">

          <!-- ========== HEADER ========== -->
          <tr>
            <td style="background-color: #111111; padding: 36px 40px; text-align: center;">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center">
                <tr>
                  <td style="font-size: 28px; font-weight: 700; color: #ffffff; letter-spacing: -0.5px;">
                    Rista<span style="color: #E8467C;">Pro</span>
                  </td>
                </tr>
              </table>
              <p style="margin: 8px 0 0; font-size: 12px; color: #888888; letter-spacing: 2px; text-transform: uppercase;">
                Linked Account Created
              </p>
            </td>
          </tr>

          <!-- ========== HERO ========== -->
          <tr>
            <td class="mobile-padding" style="padding: 48px 40px 28px; text-align: center;">
              <!-- Icon -->
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center">
                <tr>
                  <td style="width: 64px; height: 64px; background-color: #FDE8F0; border-radius: 50%; text-align: center; line-height: 64px; font-size: 28px;">
                    🔗
                  </td>
                </tr>
              </table>

              <h1 style="margin: 24px 0 0; font-size: 26px; font-weight: 700; color: #111111; line-height: 1.3;">
                Hello, <span style="color: #E8467C;"> <%= linkedUserName %> </span>!
              </h1>
              <p style="margin: 12px 0 0; font-size: 15px; color: #666666; line-height: 1.7; max-width: 440px; display: inline-block;">
                <strong style="color: #111111;"> <%= ownerName %> </strong> has added you as a linked member on RistaPro. You now have access to manage <strong style="color: #111111;"> <%= candidateName %> </strong>'s profile.
              </p>
            </td>
          </tr>

          <!-- ========== DIVIDER ========== -->
          <tr>
            <td style="padding: 0 40px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr><td style="border-top: 1px solid #f0f0f0;"></td></tr>
              </table>
            </td>
          </tr>

          <!-- ========== ACCOUNT INFO CARD ========== -->
          <tr>
            <td class="mobile-padding" style="padding: 28px 40px;">
              <table role="presentation" class="info-card" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #fafafa; border-radius: 12px; border: 1px solid #f0f0f0;">
                <tr>
                  <td style="padding: 24px 28px;">
                    <p style="margin: 0 0 16px; font-size: 13px; font-weight: 600; color: #111111; letter-spacing: 1.5px; text-transform: uppercase;">
                      Your Account Details
                    </p>

                    <!-- Row: Role -->
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 10px;">
                      <tr>
                        <td width="130" style="font-size: 13px; color: #999999; padding: 4px 0;">Role</td>
                        <td style="font-size: 14px; font-weight: 600; color: #111111; padding: 4px 0;">Linked Member</td>
                      </tr>
                    </table>
                    <!-- Row: Candidate -->
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 10px;">
                      <tr>
                        <td width="130" style="font-size: 13px; color: #999999; padding: 4px 0;">Candidate</td>
                        <td style="font-size: 14px; font-weight: 600; color: #E8467C; padding: 4px 0;"><%= candidateName %></td>
                      </tr>
                    </table>
                    <!-- Row: Added By -->
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 10px;">
                      <tr>
                        <td width="130" style="font-size: 13px; color: #999999; padding: 4px 0;">Added By</td>
                        <td style="font-size: 14px; font-weight: 600; color: #111111; padding: 4px 0;"><%= ownerName %></td>
                      </tr>
                    </table>
                    <!-- Row: Email -->
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td width="130" style="font-size: 13px; color: #999999; padding: 4px 0;">Login Email</td>
                        <td style="font-size: 14px; font-weight: 600; color: #111111; padding: 4px 0;"> <%= linkedUserEmail %> </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- ========== WHAT YOU CAN DO ========== -->
          <tr>
            <td class="mobile-padding" style="padding: 4px 40px 28px;">
              <p style="margin: 0 0 18px; font-size: 13px; font-weight: 600; color: #111111; letter-spacing: 1.5px; text-transform: uppercase;">
                What You Can Do
              </p>

              <!-- Capability 1 -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 14px;">
                <tr>
                  <td width="36" valign="top">
                    <div style="width: 28px; height: 28px; background-color: #FDE8F0; border-radius: 8px; text-align: center; line-height: 28px; font-size: 14px;">✏️</div>
                  </td>
                  <td valign="middle" style="padding-left: 10px;">
                    <p style="margin: 0; font-size: 14px; color: #333333; line-height: 1.5;">
                      <strong style="color: #111111;">Edit &amp; manage</strong> <%= candidateName %>'s profile details
                    </p>
                  </td>
                </tr>
              </table>

              <!-- Capability 2 -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 14px;">
                <tr>
                  <td width="36" valign="top">
                    <div style="width: 28px; height: 28px; background-color: #FDE8F0; border-radius: 8px; text-align: center; line-height: 28px; font-size: 14px;">💬</div>
                  </td>
                  <td valign="middle" style="padding-left: 10px;">
                    <p style="margin: 0; font-size: 14px; color: #333333; line-height: 1.5;">
                      <strong style="color: #111111;">Chat with matches</strong> on behalf of your candidate
                    </p>
                  </td>
                </tr>
              </table>

              <!-- Capability 3 -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 14px;">
                <tr>
                  <td width="36" valign="top">
                    <div style="width: 28px; height: 28px; background-color: #FDE8F0; border-radius: 8px; text-align: center; line-height: 28px; font-size: 14px;">👀</div>
                  </td>
                  <td valign="middle" style="padding-left: 10px;">
                    <p style="margin: 0; font-size: 14px; color: #333333; line-height: 1.5;">
                      <strong style="color: #111111;">Browse &amp; shortlist</strong> potential matches
                    </p>
                  </td>
                </tr>
              </table>

              <!-- Capability 4 -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td width="36" valign="top">
                    <div style="width: 28px; height: 28px; background-color: #FDE8F0; border-radius: 8px; text-align: center; line-height: 28px; font-size: 14px;">🔔</div>
                  </td>
                  <td valign="middle" style="padding-left: 10px;">
                    <p style="margin: 0; font-size: 14px; color: #333333; line-height: 1.5;">
                      <strong style="color: #111111;">Receive notifications</strong> for new interests &amp; messages
                    </p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- ========== TEMPORARY PASSWORD (conditional) ========== -->
          
          <tr>
            <td class="mobile-padding" style="padding: 0 40px 28px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #111111; border-radius: 12px;">
                <tr>
                  <td style="padding: 20px 24px; text-align: center;">
                    <p style="margin: 0 0 6px; font-size: 11px; font-weight: 600; color: #E8467C; letter-spacing: 1.5px; text-transform: uppercase;">
                      Temporary Password
                    </p>
                    <p style="margin: 0; font-size: 22px; font-weight: 700; color: #ffffff; letter-spacing: 3px; font-family: 'Courier New', monospace;">
                      <%= tempPassword %>
                    </p>
                    <p style="margin: 10px 0 0; font-size: 11px; color: #666666;">
                      Please change this after your first login.
                    </p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          

          <!-- ========== CTA BUTTON ========== -->
          <tr>
            <td class="mobile-padding" style="padding: 4px 40px 44px; text-align: center;">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center">
                <tr>
                  <td style="border-radius: 50px; background-color: #E8467C;">
                    <a  href="<%= loginUrl %>" target="_blank" style="display: inline-block; padding: 14px 40px; font-size: 15px; font-weight: 600; color: #ffffff; text-decoration: none; letter-spacing: 0.3px;">
                      Login &amp; Get Started →
                    </a>
                  </td>
                </tr>
              </table>
              <p style="margin: 16px 0 0; font-size: 12px; color: #999999;">
                Having trouble? Contact <a  href="mailto:<%= supportEmail %>">support</a> for help.
              </p>
            </td>
          </tr>

          <!-- ========== FOOTER ========== -->
          <tr>
            <td style="background-color: #111111; padding: 32px 40px; text-align: center;">
              <p style="margin: 0; font-size: 13px; font-weight: 600; color: #ffffff; letter-spacing: -0.3px;">
                Rista<span style="color: #E8467C;">Pro</span>
              </p>
              <p style="margin: 12px 0 0; font-size: 12px; color: #666666; line-height: 1.6;">
                You received this email because <strong style="color: #888888;"><%= ownerName %></strong> added you on RistaPro.<br />
                <a href="<%= termsOfService %>"  style="color: #E8467C; text-decoration: underline;">Terms & Conditions</a>&nbsp;&nbsp;·&nbsp;&nbsp;
                <a href="<%= privacyUrl  %>"  style="color: #E8467C; text-decoration: underline;">Privacy Policy</a>
              </p>
              <p style="margin: 16px 0 0; font-size: 11px; color: #444444;">
                © 2026 RistaPro. All rights reserved.
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>