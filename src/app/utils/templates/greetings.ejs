<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <title>Welcome to RistaPro</title>
  <!--[if mso]>
  <noscript>
    <xml>
      <o:OfficeDocumentSettings>
        <o:PixelsPerInch>96</o:PixelsPerInch>
      </o:OfficeDocumentSettings>
    </xml>
  </noscript>
  <![endif]-->
  <style>
    /* Reset */
    body, table, td, a { -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
    table, td { border-collapse: collapse; mso-table-lspace: 0pt; mso-table-rspace: 0pt; }
    img { -ms-interpolation-mode: bicubic; border: 0; height: auto; line-height: 100%; outline: none; text-decoration: none; }
    body { margin: 0; padding: 0; width: 100% !important; height: 100% !important; background-color: #f5f5f5; }

    /* Typography */
    body, td, p { font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; }

    /* Mobile */
    @media only screen and (max-width: 600px) {
      .email-container { width: 100% !important; }
      .fluid { max-width: 100% !important; height: auto !important; }
      .stack-column { display: block !important; width: 100% !important; }
      .mobile-padding { padding: 24px 20px !important; }
    }
  </style>
</head>
<body style="margin: 0; padding: 0; background-color: #f5f5f5;">

  <!-- preheated (hidden preview text) -->
  <div style="display: none; max-height: 0; overflow: hidden; font-size: 1px; line-height: 1px; color: #f5f5f5;">
    Welcome to RistaPro,  <%= name %>! Your journey to finding the perfect match begins now.
  </div>

  <!-- Outer wrapper -->
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #f5f5f5;">
    <tr>
      <td align="center" style="padding: 40px 16px;">

        <!-- Email container -->
        <table role="presentation" class="email-container" width="560" cellpadding="0" cellspacing="0" border="0" style="background-color: #ffffff; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.06);">

          <!-- ========== HEADER ========== -->
          <tr>
            <td style="background-color: #111111; padding: 36px 40px; text-align: center;">
              <!-- Logo / Brand -->
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center">
                <tr>
                  <td style="font-size: 28px; font-weight: 700; color: #ffffff; letter-spacing: -0.5px;">
                    Rista<span style="color: #E8467C;">Pro</span>
                  </td>
                </tr>
              </table>
              <p style="margin: 8px 0 0; font-size: 12px; color: #888888; letter-spacing: 2px; text-transform: uppercase;">
                Your Perfect Match Awaits
              </p>
            </td>
          </tr>

          <!-- ========== HERO ========== -->
          <tr>
            <td class="mobile-padding" style="padding: 48px 40px 32px; text-align: center;">
              <!-- Pink circle icon -->
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center">
                <tr>
                  <td style="width: 64px; height: 64px; background-color: #FDE8F0; border-radius: 50%; text-align: center; line-height: 64px; font-size: 28px;">
                    💕
                  </td>
                </tr>
              </table>

              <h1 style="margin: 24px 0 0; font-size: 26px; font-weight: 700; color: #111111; line-height: 1.3;">
                Welcome, <span style="color: #E8467C;"> <%= name %> </span>!
              </h1>
              <p style="margin: 12px 0 0; font-size: 15px; color: #666666; line-height: 1.7; max-width: 420px; display: inline-block;">
                We're thrilled to have you on board. Your journey to finding a meaningful, lifelong connection starts right here.
              </p>
            </td>
          </tr>

          <!-- ========== DIVIDER ========== -->
          <tr>
            <td style="padding: 0 40px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="border-top: 1px solid #f0f0f0;"></td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- ========== STEPS ========== -->
          <tr>
            <td class="mobile-padding" style="padding: 32px 40px;">
              <p style="margin: 0 0 20px; font-size: 13px; font-weight: 600; color: #111111; letter-spacing: 1.5px; text-transform: uppercase;">
                Get Started in 3 Steps
              </p>

              <!-- Step 1 -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 16px;">
                <tr>
                  <td width="40" valign="top">
                    <div style="width: 32px; height: 32px; background-color: #E8467C; border-radius: 50%; color: #ffffff; font-size: 14px; font-weight: 700; line-height: 32px; text-align: center;">1</div>
                  </td>
                  <td valign="top" style="padding-left: 12px;">
                    <p style="margin: 0; font-size: 15px; font-weight: 600; color: #111111;">Complete Your Profile</p>
                    <p style="margin: 4px 0 0; font-size: 13px; color: #888888; line-height: 1.5;">Add your photo, bio, and preferences to stand out.</p>
                  </td>
                </tr>
              </table>

              <!-- Step 2 -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 16px;">
                <tr>
                  <td width="40" valign="top">
                    <div style="width: 32px; height: 32px; background-color: #E8467C; border-radius: 50%; color: #ffffff; font-size: 14px; font-weight: 700; line-height: 32px; text-align: center;">2</div>
                  </td>
                  <td valign="top" style="padding-left: 12px;">
                    <p style="margin: 0; font-size: 15px; font-weight: 600; color: #111111;">Discover Matches</p>
                    <p style="margin: 4px 0 0; font-size: 13px; color: #888888; line-height: 1.5;">Swipe through curated profiles tailored just for you.</p>
                  </td>
                </tr>
              </table>

              <!-- Step 3 -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td width="40" valign="top">
                    <div style="width: 32px; height: 32px; background-color: #E8467C; border-radius: 50%; color: #ffffff; font-size: 14px; font-weight: 700; line-height: 32px; text-align: center;">3</div>
                  </td>
                  <td valign="top" style="padding-left: 12px;">
                    <p style="margin: 0; font-size: 15px; font-weight: 600; color: #111111;">Start a Conversation</p>
                    <p style="margin: 4px 0 0; font-size: 13px; color: #888888; line-height: 1.5;">Connect, chat, and take the first step together.</p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- ========== CTA BUTTON ========== -->
          <tr>
            <td class="mobile-padding" style="padding: 8px 40px 40px; text-align: center;">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center">
                <tr>
                  <td style="border-radius: 50px; background-color: #E8467C;">
                    <a  href="<%= profileUrl %>" target="_blank" style="display: inline-block; padding: 14px 40px; font-size: 15px; font-weight: 600; color: #ffffff; text-decoration: none; letter-spacing: 0.3px;">
                      Complete My Profile →
                    </a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- ========== FOOTER ========== -->
          <tr>
            <td style="background-color: #111111; padding: 32px 40px; text-align: center;">
              <p style="margin: 0; font-size: 13px; font-weight: 600; color: #ffffff; letter-spacing: -0.3px;">
                Rista<span style="color: #E8467C;">Pro</span>
              </p>
              <p style="margin: 12px 0 0; font-size: 12px; color: #666666; line-height: 1.6;">
                You received this email because you signed up on RistaPro.<br />
                <a  href="<%= privacyPolicy  %>" style="color: #E8467C; text-decoration: underline;">Privacy Policy</a>
                <a  href="<%= termsOfService  %>" style="color: #E8467C; text-decoration: underline;">Privacy Policy</a>
              </p>
              <p style="margin: 16px 0 0; font-size: 11px; color: #444444;">
                © 2026 RistaPro. All rights reserved.
              </p>
            </td>
          </tr>

        </table>
        <!-- /Email container -->

      </td>
    </tr>
  </table>

</body>
</html>