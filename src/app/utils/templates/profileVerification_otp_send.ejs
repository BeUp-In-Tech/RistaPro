<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Verify Your Profile</title>
  <style>
    :root {
      --primary: #9c0c3b;
      --accent: #f7d9e3;
      --text: #2c2c34;
      --muted: #6b6b7a;
      --card-bg: #ffffff;
      --border: #f0e6eb;
    }
    body {
      margin: 0;
      padding: 0;
      background: #fdf7fa;
      font-family: 'Inter', Arial, sans-serif;
      color: var(--text);
    }
    .wrapper {
      max-width: 640px;
      margin: 32px auto;
      padding: 0 16px;
    }
    .card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 16px;
      box-shadow: 0 8px 24px rgba(156, 12, 59, 0.08);
      overflow: hidden;
    }
    .header {
      background: linear-gradient(135deg, #b0134a, #ff4f81);
      color: #fff;
      padding: 24px;
    }
    .brand {
      font-size: 18px;
      font-weight: 700;
      letter-spacing: 0.5px;
    }
    .title {
      margin: 8px 0 0;
      font-size: 24px;
      font-weight: 700;
    }
    .body {
      padding: 24px;
    }
    .greeting {
      margin: 0 0 12px;
      font-size: 18px;
      font-weight: 600;
    }
    .text {
      margin: 0 0 16px;
      line-height: 1.6;
      color: var(--muted);
      font-size: 15px;
    }
    .otp-box {
      display: inline-block;
      background: var(--accent);
      color: var(--primary);
      padding: 12px 20px;
      border-radius: 12px;
      font-size: 26px;
      font-weight: 800;
      letter-spacing: 4px;
      margin: 12px 0 8px;
    }
    .note {
      font-size: 13px;
      color: var(--muted);
      margin: 0 0 20px;
    }
    .divider {
      border-top: 1px solid var(--border);
      margin: 20px 0;
    }
    .footer {
      padding: 0 24px 24px;
      font-size: 12px;
      color: var(--muted);
      line-height: 1.6;
    }
    @media (max-width: 480px) {
      .otp-box { font-size: 22px; letter-spacing: 3px; }
      .title { font-size: 20px; }
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="card">
      <div class="header">
        <div class="brand">RistaPro</div>
        <div class="title">Profile Verification Code</div>
      </div>
      <div class="body">
        <p class="greeting">Hi <%= name %>,</p>
        <p class="text">
          Use the one-time code below to verify your profile. This code stays active for <strong><%= expirationTime %> minutes</strong>.
        </p>
        <div class="otp-box"><%= otp %></div>
        <p class="note">If you did not request this verification, you can safely ignore this email.</p>
        <div class="divider"></div>
        <div class="footer">
          <div>Need help? Reply to this email and we'll assist.</div>
          <div>&copy; <%= new Date().getFullYear() %> RistaPro</div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
